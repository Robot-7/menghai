<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC
        "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping package="com.oldmountain.dzm.entity">
	<class name="com.oldmountain.dzm.entity.PayInfo" table="wBuyPropPay" mutable = "false" >
		<id name="id" column="id">
			<generator class="native" />
		</id>
		<property name="playerId" column="playerId" type="int"/>
		<property name="propId" column="propId" type="int"/>
        <property name="payType" column="payType" type="int"/>
		<property name="buyNum" column="buyNum" type="int"/>
		<property name="originalCash" column="originalCash" type="int"/>
		<property name="consumeCash" column="consumeCash" type="int"/>
		<property name="surplusCash" column="surplusCash" type="int"/>
		<property name="oprTime" column="oprTime" type="int"/>
	</class>
</hibernate-mapping>