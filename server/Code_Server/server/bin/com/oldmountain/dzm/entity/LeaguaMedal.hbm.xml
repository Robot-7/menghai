<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC
        "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping package="com.oldmountain.dzm.entity">
	<class name="LeaguaMedal" table="leaguamedal" dynamic-update="true" dynamic-insert="true">
		<id name="id" column="id">
			<generator class="native" />
		</id>
		<property name="medalId" column="medalId" type="int"></property>
		<property name="ownerLeaguaID" column="ownerLeaguaID" type="int"></property>
		<property name="ownerLeaguaName" column="ownerLeaguaName" type="string"></property>
		<property name="count" column="count" type="int"></property>
	</class>
</hibernate-mapping>