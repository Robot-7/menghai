<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC
        "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping package="com.oldmountain.dzm.entity">
	<class name="Reward" table="rewards" dynamic-update="true" dynamic-insert="true">
        <id name="id" column="id">
            <generator class="native" />
        </id>
		<property name="playerId" column="playerId" type="int"/>
		<property name="rewardType" column="rewardType" type="int"/>
		<property name="rewardMsg" column="rewardMsg" type="string"/>
		<property name="rewardInfo" column="rewardInfo" type="string"/>
		<property name="rewardContent" column="rewardContent" type="string"/>
		<property name="status" column="status" type="int"/>
		<property name="addTime" column="addTime" type="int"/>
		<property name="rewardTime" column="rewardTime" type="int"/>
	</class>
</hibernate-mapping>