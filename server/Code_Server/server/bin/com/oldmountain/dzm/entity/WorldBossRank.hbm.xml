<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC
        "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping package="com.oldmountain.dzm.entity">
	<class name="WorldBossRank" table="worldbossrank" dynamic-update="true" dynamic-insert="true">
		<id name="id" column="id">
			<generator class="native" />
		</id>
		<property name="playerid" column="playerid" type="int"></property>
		<property name="rank" column="rank" type="int"></property>
		<property name="level" column="level" type="int"></property>
		<property name="name" column="name" type="string"/>
		<property name="damage" column="damage" type="int"></property>
		<property name="ranktime" column="ranktime" type="int"></property>
	</class>
</hibernate-mapping>