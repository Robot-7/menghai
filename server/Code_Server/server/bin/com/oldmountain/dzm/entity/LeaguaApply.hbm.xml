<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC
        "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping package="com.oldmountain.dzm.entity">
	<class name="LeaguaApply" table="leaguaapply" dynamic-update="true" dynamic-insert="true">
		<id name="id" column="id">
			<generator class="native" />
		</id>
		<property name="playerId" column="playerId" type="int"></property>
		<property name="playerName" column="playerName" type="string"></property>
		<property name="playerLevel" column="playerLevel" type="int"></property>
		<property name="applyTime" column="applyTime" type="int"></property>
		<property name="applyLeaguaId" column="applyLeaguaId" type="int"></property>
	</class>
</hibernate-mapping>