<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC
        "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping package="com.oldmountain.dzm.entity">
	<class name="SkillBook" table="skillbook" dynamic-update="true" dynamic-insert="true">
		<id name="id" column="id">
			<generator class="native" />
		</id>
		<property name="playerId" column="playerid" type="int"/>
		<property name="skillId" column="skillId" type="int"/>
		<property name="pieceChance" column="pieceChance" type="int"/>
		<property name="skillBookDetail" column="skillBookDetail" type="string"/>
	</class>
</hibernate-mapping>