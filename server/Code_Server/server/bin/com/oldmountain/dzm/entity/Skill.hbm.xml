<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC
        "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping package="com.oldmountain.dzm.entity">
	<class name="Skill" table="skill" dynamic-update="true" dynamic-insert="true">
		<id name="id" column="id">
			<generator class="native" />
		</id>
		<property name="playerid" column="playerid" type="int"></property>
		<property name="itemid" column="itemid" type="int"></property>
		<property name="type" column="type" type="int"></property>
		<property name="level" column="level" type="int"></property>
		<property name="quantity" column="quantity" type="float"></property>
		<property name="consume" column="consume" type="int"></property>
		<property name="battleid" column="battleid" type="int"></property>
		<property name="isdefaultskill" column="isdefaultskill" type="int"></property>
		<property name="expiretime" column="expire_time" type="int"></property>
	</class>
</hibernate-mapping>