<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC
        "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping package="com.oldmountain.dzm.entity">
	<class name="Disciple" table="disciple" dynamic-update="true" dynamic-insert="true">
		<id name="id" column="id">
			<generator class="native" />
		</id>
		<property name="playerid" column="playerid" type="int"></property>
		<property name="itemid" column="itemid" type="int"></property>
		<property name="level" column="level" type="int"></property>
		<property name="exp" column="exp" type="int"></property>
		<property name="health" column="health" type="float"></property>
		<property name="attack" column="attack" type="float"/>
		<property name="defence" column="defence" type="float"></property>
		<property name="rp" column="rp" type="float"></property>
		<property name="upgradelevel" column="upgradelevel" type="int"></property>
		<property name="potentiality" column="potentiality" type="int"></property>
		<property name="skill1" column="skill1" type="int"></property>
		<property name="battleid" column="battleid" type="int"></property>
		<property name="expiretime" column="expire_time" type="int"></property>
	</class>
</hibernate-mapping>