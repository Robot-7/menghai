<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC
        "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping package="com.oldmountain.dzm.entity">
	<class name="Battle" table="battle" dynamic-update="true" dynamic-insert="true">
		<id name="id" column="id">
			<generator class="native" />
		</id>
		<property name="playerid" column="playerid" type="int"></property>
		<property name="discipleid" column="discipleid" type="int"></property>
		<property name="itemid" column="itemid" type="int"></property>
		<property name="level" column="level" type="int"></property>
		<property name="attack" column="attack" type="int"></property>
		<property name="defence" column="defence" type="int"></property>
		<property name="health" column="health" type="int"></property>
		<property name="rp" column="rp" type="int"></property>
		<property name="defaultskill" column="defaultSkill" type="int"></property>
		<property name="defaultskilltype" column="defaultSkillType" type="int"></property>
		<property name="defaultskillitem" column="defaultSkillItem" type="int"></property>
		<property name="defaultskillquantity" column="defaultSkillQuantity" type="float"></property>
		<property name="skill1" column="skill1" type="int"></property>
		<property name="skill1item" column="skill1item" type="int"></property>
		<property name="skill1type" column="skill1Type" type="int"></property>
		<property name="skill1quantity" column="skill1Quantity" type="float"></property>
		<property name="skill2" column="skill2" type="int"></property>
		<property name="skill2item" column="skill2item" type="int"></property>
		<property name="skill2type" column="skill2Type" type="int"></property>
		<property name="skill2quantity" column="skill2Quantity" type="float"></property>
		<property name="equip1" column="equip1" type="int"></property>
		<property name="equip1item" column="equip1item" type="int"></property>
		<property name="equip2" column="equip2" type="int"></property>
		<property name="equip2item" column="equip2item" type="int"></property>
		<property name="equip3" column="equip3" type="int"></property>
		<property name="equip3item" column="equip3item" type="int"></property>
		<property name="fates" column="fates" type="string"></property>
		<property name="fatesstatus" column="fatesstatus" type="string"></property>
	</class>
</hibernate-mapping>