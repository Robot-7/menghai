<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC
        "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping package="com.oldmountain.dzm.entity">
	<class name="LeaguaMedalChangeInfo" table="leaguamedalchangeinfo" dynamic-update="true" dynamic-insert="true">
		<id name="id" column="id">
			<generator class="native" />
		</id>
		<property name="medalId" column="medalId" type="int"></property>
		<property name="beforeOwnerLeaguaName" column="beforeOwnerLeaguaName" type="string"></property>
		<property name="afterOwnerLeaguaName" column="afterOwnerLeaguaName" type="string"></property>
		<property name="changeTime" column="changeTime" type="int"></property>
	</class>
</hibernate-mapping>