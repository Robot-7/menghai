<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:background="@android:color/white" >

    <LinearLayout
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:background="@android:color/white"
        android:orientation="vertical"
        android:paddingBottom="@dimen/size_20" >

        <RelativeLayout
            android:id="@+id/linearLayout2"
            android:layout_width="fill_parent"
            android:layout_height="@dimen/size_48"
            android:layout_gravity="center_vertical"
            android:layout_marginTop="@dimen/size_10" >

            <Button
                android:id="@+id/tel_getcode_tv"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/size_40"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true"
                android:layout_marginLeft="@dimen/size_10"
                android:layout_marginRight="10dip"
                android:background="@drawable/anzhi_button_bg_gray"
                android:gravity="center"
                android:text="  获取验证码  "
                android:textColor="#545454"
                android:textSize="@dimen/font_18" />

            <LinearLayout
                android:layout_width="fill_parent"
                android:layout_height="@dimen/size_48"
                android:layout_marginLeft="@dimen/size_10"
                android:layout_toLeftOf="@id/tel_getcode_tv"
                android:background="@drawable/anzhi_textview_normal" >

                <LinearLayout
                    android:layout_width="fill_parent"
                    android:layout_height="fill_parent"
                    android:layout_gravity="center_vertical"
                    android:background="@android:color/white" >

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_gravity="center_vertical"
                        android:layout_margin="@dimen/size_10"
                        android:text="手机:"
                        android:textColor="#494949"
                        android:textSize="@dimen/font_18" />

                    <EditText
                        android:id="@+id/nameid_tel"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_gravity="center_vertical"
                        android:background="@null"
                        android:hint="请输入手机号码"
                        android:inputType="phone"
                        android:paddingRight="5dip"
                        android:singleLine="true"
                        android:textColor="#494949"
                        android:textColorHint="#d0d0d0"
                        android:textSize="@dimen/font_18" >

                        <requestFocus />
                    </EditText>
                </LinearLayout>
            </LinearLayout>
        </RelativeLayout>

        <RelativeLayout
            android:layout_width="fill_parent"
            android:layout_height="@dimen/size_48"
            android:layout_marginLeft="@dimen/size_10"
            android:layout_marginRight="@dimen/size_10"
            android:layout_marginTop="@dimen/size_10"
            android:background="@drawable/anzhi_input_normal" >

            <RelativeLayout
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:layout_centerVertical="true"
                android:background="@android:color/white" >

                <TextView
                    android:id="@+id/code_tv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_margin="@dimen/size_10"
                    android:text="验证码:"
                    android:textColor="#494949"
                    android:textSize="@dimen/font_18" />

                <EditText
                    android:id="@+id/code_edit"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginRight="@dimen/size_10"
                    android:layout_toRightOf="@id/code_tv"
                    android:background="@null"
                    android:hint="请输入6位验证码"
                    android:inputType="number"
                    android:paddingLeft="@dimen/size_10"
                    android:paddingRight="5dip"
                    android:singleLine="true"
                    android:textColor="#494949"
                    android:textColorHint="#d0d0d0"
                    android:textSize="@dimen/font_18" >

                    <requestFocus />
                </EditText>
            </RelativeLayout>
        </RelativeLayout>

        <LinearLayout
            android:id="@+id/pwd_linearlayout"
            android:layout_width="fill_parent"
            android:layout_height="@dimen/size_48"
            android:layout_marginLeft="@dimen/size_10"
            android:layout_marginRight="@dimen/size_10"
            android:layout_marginTop="@dimen/size_10"
            android:background="@drawable/anzhi_input_normal"
            android:visibility="visible" >

            <LinearLayout
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:layout_gravity="center_vertical"
                android:background="@android:color/white" >

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:layout_margin="@dimen/size_10"
                    android:text="新密码:"
                    android:textColor="#494949"
                    android:textSize="@dimen/font_18" />

                <EditText
                    android:id="@+id/pwd_edittext"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:layout_marginRight="@dimen/size_10"
                    android:background="@null"
                    android:hint="6位数以上的字母或数字"
                    android:paddingLeft="@dimen/size_10"
                    android:paddingRight="5dip"
                    android:password="true"
                    android:inputType="textPassword"
                    android:singleLine="true"
                    android:textColor="#494949"
                    android:textColorHint="#d0d0d0"
                    android:textSize="@dimen/font_18" >

                    <requestFocus />
                </EditText>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/pwd_linearlayout2"
            android:layout_width="fill_parent"
            android:layout_height="@dimen/size_48"
            android:layout_marginLeft="@dimen/size_10"
            android:layout_marginRight="@dimen/size_10"
            android:layout_marginTop="@dimen/size_10"
            android:background="@drawable/anzhi_input_normal"
            android:visibility="visible" >

            <LinearLayout
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:layout_gravity="center_vertical"
                android:background="@android:color/white" >

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:layout_margin="@dimen/size_10"
                    android:text="确认密码:"
                    android:textColor="#494949"
                    android:textSize="@dimen/font_18" />

                <EditText
                    android:id="@+id/pwd_edittext2"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:layout_marginRight="@dimen/size_10"
                    android:background="@null"
                    android:hint="请再次输入密码"
                    android:paddingLeft="@dimen/size_10"
                    android:paddingRight="5dip"
                    android:password="true"
                    android:singleLine="true"
                    android:textColor="#494949"
                    android:inputType="textPassword"
                    android:textColorHint="#d0d0d0"
                    android:textSize="@dimen/font_18" >

                    <requestFocus />
                </EditText>
            </LinearLayout>
        </LinearLayout>

        <Button
            android:id="@+id/tim_imageview"
            android:layout_width="fill_parent"
            android:layout_height="@dimen/size_40"
            android:layout_gravity="center_horizontal"
            android:layout_marginLeft="@dimen/size_40"
            android:layout_marginRight="@dimen/size_40"
            android:layout_marginTop="@dimen/size_40"
            android:background="@drawable/anzhi_button_bg"
            android:text="保存"
            android:textColor="@android:color/white"
            android:textSize="@dimen/font_18" />

        <TextView
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/size_10"
            android:layout_marginRight="@dimen/size_10"
            android:layout_marginTop="@dimen/size_40"
            android:text="温馨提示"
            android:textColor="#757575"
            android:textSize="@dimen/font_14" />

        <TextView
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/size_10"
            android:layout_marginRight="@dimen/size_10"
            android:layout_marginTop="@dimen/size_10"
            android:text="1.请确认您的手机能够正常收到短信"
            android:textColor="#757575"
            android:textSize="@dimen/font_14" />

        <TextView
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/size_10"
            android:layout_marginRight="@dimen/size_10"
            android:text="2.点击获取验证码，您将收到6位数字的验证码"
            android:textColor="#757575"
            android:textSize="@dimen/font_14" />

        <TextView
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/size_10"
            android:layout_marginRight="@dimen/size_10"
            android:text="3.验证码一次有效，以最后接收的验证码为准"
            android:textColor="#757575"
            android:textSize="@dimen/font_14" />
    </LinearLayout>

</RelativeLayout>