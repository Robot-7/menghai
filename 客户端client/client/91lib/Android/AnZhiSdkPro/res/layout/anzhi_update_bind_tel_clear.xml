<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:background="@android:color/white" >

    <ScrollView
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:background="@android:color/white" >

        <LinearLayout
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            android:orientation="vertical"
            android:paddingBottom="@dimen/size_20" >

            <TextView
                android:id="@+id/tel_ttvv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginLeft="@dimen/size_10"
                android:layout_marginTop="@dimen/size_10"
                android:text="请输入手机号"
                android:textColor="#494949"
                android:textSize="@dimen/font_18" />

            <RelativeLayout
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/size_5" >

                <Button
                    android:id="@+id/getcode_b"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/size_40"
                    android:layout_alignParentRight="true"
                    android:layout_centerVertical="true"
                    android:layout_marginRight="10dip"
                    android:background="@drawable/anzhi_button_bg_gray"
                    android:text="  获取验证码  "
                    android:textColor="#545454"
                    android:textSize="@dimen/font_18" />

                <RelativeLayout
                    android:layout_width="fill_parent"
                    android:layout_height="@dimen/size_48"
                    android:layout_centerVertical="true"
                    android:layout_marginLeft="@dimen/size_10"
                    android:layout_marginRight="10dip"
                    android:layout_toLeftOf="@id/getcode_b"
                    android:background="@drawable/anzhi_textview_normal" >
<RelativeLayout
                        android:layout_width="fill_parent"
                        android:layout_height="fill_parent"
                        android:layout_centerVertical="true"
                        android:background="@android:color/white" >
                    <EditText
                        android:id="@+id/tel_et"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_toLeftOf="@id/getcode_b"
                        android:layout_toRightOf="@id/tel_ttvv"
                        android:background="@null"
                        android:enabled="false"
                        android:hint="请输入手机号码"
                        android:inputType="phone"
                        android:paddingLeft="5dip"
                        android:paddingRight="5dip"
                        android:singleLine="true"
                        android:textColor="#494949"
                        android:textColorHint="#d0d0d0"
                        android:textSize="@dimen/font_18" >

                        <requestFocus />
                    </EditText>
                    </RelativeLayout>
                </RelativeLayout>
            </RelativeLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/size_10"
                android:layout_marginTop="@dimen/size_10"
                android:text="验证码"
                android:textColor="#494949"
                android:textSize="@dimen/font_18" />

            <LinearLayout
                android:layout_width="fill_parent"
                android:layout_height="@dimen/size_48"
                android:layout_marginLeft="@dimen/size_10"
                android:layout_marginRight="@dimen/size_10"
                android:layout_marginTop="@dimen/size_5"
                android:background="@drawable/anzhi_input_normal" >
  <LinearLayout
                    android:layout_width="fill_parent"
                    android:layout_height="fill_parent"
                    android:layout_gravity="center_vertical"
                    android:background="@android:color/white" >
                <EditText
                    android:id="@+id/code_et"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:hint="请输入6位短信验证码"
                    android:layout_gravity="center_vertical"
                    android:inputType="number"
                    android:paddingLeft="5dip"
                    android:paddingRight="5dip"
                    android:textColor="#494949"
                    android:textColorHint="#d0d0d0"
                    android:textSize="@dimen/font_18" >

                    <requestFocus />
                </EditText>
                </LinearLayout>
            </LinearLayout>

            <Button
                android:id="@+id/bind_tv"
                android:layout_width="fill_parent"
                android:layout_height="@dimen/size_40"
                android:layout_gravity="center_horizontal"
                android:layout_marginLeft="@dimen/size_40"
                android:layout_marginRight="@dimen/size_40"
                android:layout_marginTop="@dimen/size_40"
                android:background="@drawable/anzhi_button_bg"
                android:text="解除绑定"
                android:textColor="@android:color/white"
                android:textSize="@dimen/font_18" />

            <TextView
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/size_10"
                android:layout_marginRight="@dimen/size_10"
                android:layout_marginTop="@dimen/size_40"
                android:text="温馨提示"
                android:textColor="#757575"
                android:textSize="@dimen/font_14" />

            <TextView
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/size_10"
                android:layout_marginRight="@dimen/size_10"
                android:layout_marginTop="@dimen/size_10"
                android:text="1.请确认您的手机处于信号通畅且可接收短信状态"
                android:textColor="#757575"
                android:textSize="@dimen/font_14" />

            <TextView
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/size_10"
                android:layout_marginRight="@dimen/size_10"
                android:text="2.点击获取验证码，您将收到6位数字的验证码"
                android:textColor="#757575"
                android:textSize="@dimen/font_14" />

            <TextView
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/size_10"
                android:layout_marginRight="@dimen/size_10"
                android:text="3.验证码一次有效，以最后接收的验证码为准"
                android:textColor="#757575"
                android:textSize="@dimen/font_14" />
        </LinearLayout>
    </ScrollView>

</RelativeLayout>