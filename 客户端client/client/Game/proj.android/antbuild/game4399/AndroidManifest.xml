            android:value="channel_270" />
        <!-- 添加4399大小包标识 -->
        <meta-data
            android:name="com.ssjjsy.packageType"
            android:value="packageType_1" />
        <!-- 添加4399 包标识，如普清为 1，高清 2，默认情况为1 ，如果没有高清或者普清，只有小包，这样可以不添加以下代码 -->
        <meta-data
            android:name="com.ssjjsy.packageHd"
            android:value="packageHd_1" />
        <activity
   		android:name="com.youai.dreamonepiece.platform.sy4399.wxapi.WXEntryActivity"
