<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.youai.dreamonepiece.platform.uc"
    android:versionCode="3"
    android:versionName="1.3" 
    android:installLocation="preferExternal">

    <!-- 发布通过Android Tools修改package name -->
    
    <uses-sdk
        android:minSdkVersion="9"
        android:targetSdkVersion="16" />
    
    <uses-feature android:glEsVersion="0x00020000" />
    
    <uses-permission android:name="android.permission.EXPAND_STATUS_BAR"/>
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"/>
	<uses-permission android:name="android.permission.READ_PHONE_STATE"/>
	<uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>
	<uses-permission android:name="android.permission.INTERNET" />
	<uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
	<uses-permission android:name="android.permission.MOUNT_UNMOUNT_FILESYSTEMS"/>
    <uses-permission android:name="android.permission.GET_TASKS" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW"/>
    
    <uses-permission android:name="android.permission.SEND_SMS" />
    <uses-permission android:name="android.permission.RECEIVE_SMS" />
    <uses-permission android:name="android.permission.CALL_PHONE" />
    
    <supports-screens android:largeScreens="true"
                      android:smallScreens="true"
                      android:anyDensity="true"
                      android:normalScreens="true"
                      android:xlargeScreens="true"/>

    <!-- android:debuggable="true" ADT&NDK自动处理了 -->
    
    <!-- 发布修改icon -->
    
    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_uc"
        android:label="@string/app_name"
        android:theme="@android:style/Theme.NoTitleBar.Fullscreen" 
        android:largeHeap="true" 
        android:vmSafeMode="false" 
        android:allowClearUserData="true"
        android:debuggable="false">     
         
       <activity
            android:name="com.youai.dreamonepiece.platform.uc.UcActivity"
            android:label="@string/app_name"
            android:theme="@android:style/Theme.NoTitleBar.Fullscreen" 
            android:launchMode="singleTop" 
            android:screenOrientation="portrait">
                
             <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            
        </activity>
        
			<!-- 发送notification消息 -->
			<service android:name="com.youai.dreamonepiece.NotificationService"></service>       
        <!-- begin UC -->
        <activity android:configChanges="keyboardHidden|orientation|screenSize"
			android:label="@string/app_name" android:name="cn.uc.gamesdk.view.SdkWebActivity"
			android:theme="@android:style/Theme.Translucent"
			android:windowSoftInputMode="adjustResize">
			<intent-filter>
				<action android:name="cn.uc.gamesdk.sdkweb"/>
				<category android:name="android.intent.category.DEFAULT"/>
			</intent-filter>
		</activity>
        <!-- end UC -->			
		
    </application>

</manifest>