<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.youai.dreamonepiece.platform.punchbox"
    android:versionCode="3"
    android:versionName="1.3" 
    android:installLocation="preferExternal">

    <!-- 发布通过Android Tools修改package name -->
    
    <uses-sdk
        android:minSdkVersion="9"
        android:targetSdkVersion="16" />
    
    <uses-feature android:glEsVersion="0x00020000" />
    
    <uses-permission android:name="android.permission.EXPAND_STATUS_BAR"/>
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"/>
	<uses-permission android:name="android.permission.READ_PHONE_STATE"/>
	<uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>
	<uses-permission android:name="android.permission.INTERNET" />
	<uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
	<uses-permission android:name="android.permission.MOUNT_UNMOUNT_FILESYSTEMS"/>
    <uses-permission android:name="android.permission.GET_TASKS" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW"/>
    
    <uses-permission android:name="android.permission.SEND_SMS" />
    <uses-permission android:name="android.permission.RECEIVE_SMS" />
    <uses-permission android:name="android.permission.CALL_PHONE" />

    <!-- 触控权限 -->
	<uses-permission android:name="android.permission.VIBRATE"/>
	<uses-permission android:name= "android.permission.GET_ACCOUNTS"/>
	<uses-permission android:name="android.permission.RESTART_PACKAGES"/>
    <uses-permission android:name="android.permission.RECORD_AUDIO"/>
    <uses-permission android:name= "android.permission.WRITE_CONTACTS"/>
    <uses-permission android:name= "android.permission.READ_CONTACTS"/>
    <!-- end 触控权限 -->
    
    <supports-screens android:largeScreens="true"
                      android:smallScreens="true"
                      android:anyDensity="true"
                      android:normalScreens="true"
                      android:xlargeScreens="true"/>

    <!-- android:debuggable="true" ADT&NDK自动处理了 -->
    
    <!-- 发布修改icon -->
    
    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:theme="@android:style/Theme.NoTitleBar.Fullscreen" 
        android:largeHeap="true" 
        android:vmSafeMode="false" 
        android:allowClearUserData="true"
        android:debuggable="false">
        
        <!-- 发布指定平台：
        0   defaultplatform.DefaultActivity
        1	nd91.Nd91Activity
        2	uc.UcActivity
        3	qihoo360.Qihoo360Activity
        4	dangle.DangLeActivity
        5	mi.XiaoMiActivity
        6	wandoujia.WanDouJiaActivity
        7   DK.DuokuActivity
        11  feiliu.FeiLiuActivity
        12  jifeng.JiFengActivity
        13  anzhi.AnZhiActivity
        14  renren.RenRenActivity
        16  sy4399.SSJJActivity
        17  yingyonghui.YingYongHuiActivity
        22 	thirdlogin.ThirdLoginActivity
        23  kingsoft.JinShanActivity
        24  baidugame.BaiDuGameActivity
        25  ld.LvDouGameActivity
        10  kuwo.KuWoActivity
        27  punchbox.ChuKongActivity
        -->
        <!-- 飞流需要把  android:launchMode="singleTask" 其他用  singleTop -->
        
       <activity
            android:name="com.youai.dreamonepiece.platform.punchbox.ChuKongActivity"
            android:label="@string/app_name"
            android:theme="@android:style/Theme.NoTitleBar.Fullscreen" 
            android:launchMode="singleTop"
            android:screenOrientation="portrait">
                
             <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>       
        </activity>
        
			<!-- 发送notification消息 -->
			<service android:name="com.youai.dreamonepiece.NotificationService"></service>       
	
		
		<!-- begin 触控 -->
		<!-- 触控支付-->
		<activity
		    android:name="cn.iyd.iydpay_apk.IydpayActivity"
		    android:screenOrientation="portrait"
		    android:exported="true"
		    android:theme="@android:style/Theme.Translucent.NoTitleBar">
		</activity>
		<service android:name="cn.iyd.iydpay_apk.IydpayService" />
		<service android:name="cn.iyd.iydpay_apk.PunchboxService">
		      <intent-filter android:priority="1000">
				<action android:name="com.youai.dreamonepiece.platform.punchbox.iydpay"/>
		        <category android:name="android.intent.category.DEFAULT"/>
		      </intent-filter>
		</service>
		<!-- 触控支付-->
		<!-- 单机移动-->
		<activity android:name="cn.emagsoftware.gamebilling.activity.BillingActivity"
		      android:windowSoftInputMode="stateHidden"
		  android:configChanges="orientation|keyboardHidden"> 
		</activity>
		<!-- 单机移动-->
		<!-- 银联-->
		    <activity
		      android:name="com.unionpay.upomp.lthj.plugin.ui.SplashActivity"
		      android:screenOrientation="portrait">
		      <intent-filter>
		      <action android:name="com.unionpay.upomp.lthj.android.plugin.init.test"/>
		        <category android:name="android.intent.category.DEFAULT"/>
		      </intent-filter>
		    </activity>
		    <activity
		  android:name="com.unionpay.upomp.lthj.plugin.ui.IndexActivityGroup"
		  android:screenOrientation="portrait">
		  <intent-filter>
		    <action
		    android:name="com.unionpay.upomp.lthj.android.plugin.index.test"/>
		    <category android:name="android.intent.category.DEFAULT"/>
		  </intent-filter>
		</activity>
		<activity
		  android:name="com.unionpay.upomp.lthj.plugin.ui.HomeActivity"
		  android:screenOrientation="portrait">
		</activity>
		<activity
		  android:name="com.unionpay.upomp.lthj.plugin.ui.PayActivity"
		  android:screenOrientation="portrait">
		</activity>
		<activity
		  android:name="com.unionpay.upomp.lthj.plugin.ui.AccountActivity"
		  android:screenOrientation="portrait">
		</activity>
		<activity
		  android:name="com.unionpay.upomp.lthj.plugin.ui.BankCardInfoActivity"
		  android:screenOrientation="portrait">
		</activity>
		<activity
		  android:name="com.unionpay.upomp.lthj.plugin.ui.SupportCardActivity"
		  android:screenOrientation="portrait">
		</activity>
		<activity
		  android:name="com.unionpay.upomp.lthj.plugin.ui.UserProtocolActivity"
		  android:screenOrientation="portrait">
		</activity>
		<activity
		  android:name="com.unionpay.upomp.lthj.plugin.ui.AboutActivity"
		  android:screenOrientation="portrait">
		</activity>
		<activity
		  android:name="com.tcl.hyt.unionpay.plugin.activity.IndexActivity"
		  android:configChanges="keyboardHidden|orientation"
		  android:theme="@android:style/Theme.NoTitleBar"/>
		<activity
		  android:name="com.tcl.hyt.unionpay.plugin.activity.LoadingActivity"
		  android:configChanges="keyboardHidden|orientation"
		  android:theme="@android:style/Theme.NoTitleBar"/>
		<!-- 银联--> <!-- 电信-->
		<activity
		 android:name="com.egame.webfee.ui.EgameSdkWebFeeActivity"
		 android:theme="@android:style/Theme.Black.NoTitleBar.Fullscreen">
		</activity>
		<!-- 电信-->
		<service android:enabled="true"
		      android:name="joy.sdk.JoyService"
		      android:process=":remote">
		      <intent-filter>
		        <action android:name="com.joy.pushservice"/>
		      </intent-filter>
		</service>
		<!-- ======================================= -->
		<receiver android:name="com.punchbox.hound.monitor.ArchiveMonitorReceiver"> 
            <intent-filter> 
                <action android:name="android.net.conn.CONNECTIVITY_CHANGE" /> 
                <action android:name="android.intent.action.USER_PRESENT" /> 
            </intent-filter> 
             
             <intent-filter > 
                <action android:name="android.intent.action.PACKAGE_ADDED" /> 
                <data android:scheme="package" /> 
            </intent-filter> 
        </receiver>   
		<service  
            android:name="com.punchbox.hound.monitor.ArchiveMonitorDownloadService" 
            android:enabled="true" 
            android:label="DownloadService" 
            android:process="org.punchbox.service" > 
        </service> 
         
        <receiver android:name="com.punchbox.hound.monitor.CheckBootBroadcastReceiver" > 
            <intent-filter> 
                <action android:name="android.intent.action.BOOT_COMPLETED" /> 
                <action android:name="android.net.conn.CONNECTIVITY_CHANGE" /> 
            </intent-filter> 
             
        </receiver> 
 
        <service android:name="com.punchbox.hound.monitor.CheckUpdateService" > 
            <intent_filter> 
                <category android:name="android.intent.category.default" /> 
            </intent_filter> 
        </service>
		<!-- end 触控 -->
		<meta-data
            android:name="chukong_channel"
            android:value="900038" />
		<meta-data
            android:name="chukong_boxid"
            android:value="100006" />
    </application>

</manifest>