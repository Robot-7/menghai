<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.youai.dreamonepiece.platform.DK"
    android:versionCode="3"
    android:versionName="1.3" 
    android:installLocation="preferExternal">

    <!-- 发布通过Android Tools修改package name -->
    
    <uses-sdk
        android:minSdkVersion="9"
        android:targetSdkVersion="16" />
    
    <uses-feature android:glEsVersion="0x00020000" />
    
	<!-- -->
    <uses-permission android:name="android.permission.EXPAND_STATUS_BAR"/>
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"/>
	<uses-permission android:name="android.permission.READ_PHONE_STATE"/>
	<uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>
	<uses-permission android:name="android.permission.INTERNET" />
	<uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.GET_TASKS" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW"/>
    <uses-permission android:name="android.permission.SEND_SMS" />
    <uses-permission android:name="android.permission.RECEIVE_SMS" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.MOUNT_UNMOUNT_FILESYSTEMS" />
    <uses-permission android:name="android.permission.CALL_PHONE" />
    <uses-permission android:name="android.permission.WRITE_SETTINGS"/>
	<!-- -->
    
    <supports-screens android:largeScreens="true"
                      android:smallScreens="true"
                      android:anyDensity="true"
                      android:normalScreens="true"
                      android:xlargeScreens="true"/>

    <!-- android:debuggable="true" ADT&NDK自动处理了 -->
    
    <!-- 发布修改icon -->
    
    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_duoku"
        android:label="@string/app_name"
        android:theme="@android:style/Theme.NoTitleBar.Fullscreen" 
        android:largeHeap="true" 
        android:vmSafeMode="false" 
        android:allowClearUserData="true"
        android:debuggable="true">
        
        <!-- 发布指定平台：
        0   defaultplatform.DefaultActivity
        1	nd91.Nd91Activity
        2	uc.UcActivity
        3	qihoo360.Qihoo360Activity
        4	dangle.DangLeActivity
        5	mi.XiaoMiActivity
        6	wandoujia.WanDouJiaActivity
        7   DK.DuokuActivity
        14  renren.RenRenActivity
        22 	thirdlogin.ThirdLoginActivity
         -->
         
       <activity
            android:name="com.youai.dreamonepiece.platform.DK.DuokuActivity"
            android:label="@string/app_name"
            android:theme="@android:style/Theme.NoTitleBar.Fullscreen" 
            android:launchMode="singleTop" 
            android:screenOrientation="portrait">
                
             <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            
        </activity>
        
		<!-- 发送notification消息 -->
		<service android:name="com.youai.dreamonepiece.NotificationService"></service>       
        <!--  -->
        
       <!-- start duoku -->
		<meta-data android:name="DUOKUSDK_CHANNEL" 
           android:value="700" />
		 <activity
            android:name="com.duoku.platform.ui.DKPaymentCenterActivity"
            android:configChanges="orientation|keyboardHidden|navigation"
            android:theme="@style/DK.Theme.NoBackGround"
            android:screenOrientation="portrait">
        </activity>
        <activity
            android:name="com.duoku.platform.ui.DKLoginActivity"
            android:configChanges="orientation|keyboardHidden|navigation"
            android:screenOrientation="portrait"
            android:theme="@style/DK.Theme.NoBackGround.NoAnimation">
        </activity>
        <activity
            android:name="com.duoku.platform.ui.DKAccountManagerActivity"
            android:configChanges="orientation|keyboardHidden|navigation"
            android:screenOrientation="portrait"
            android:theme="@style/DK.Theme.NoBackGround.NoAnimation">
        </activity>
        <activity
            android:name="com.duoku.platform.ui.DKLoginBdActivity"
            android:configChanges="orientation|keyboardHidden|navigation"
            android:theme="@style/DK.Theme.NoBackGround.NoAnimation"
            android:screenOrientation="portrait">
        </activity>
        <activity
            android:name="com.duoku.platform.ui.DKRegisterActivity"
            android:configChanges="orientation|keyboardHidden|navigation"
            android:theme="@style/DK.Theme.NoBackGround.NoAnimation"
            android:screenOrientation="portrait">
        </activity>
        <activity
            android:name="com.duoku.platform.ui.DKFindPwdHintActivity"
            android:configChanges="orientation|keyboardHidden|navigation"
            android:excludeFromRecents="true"
            android:theme="@style/DK.Theme.NoBackGround.NoAnimation"
            android:screenOrientation="portrait">
        </activity>
        <activity
            android:name="com.duoku.platform.ui.DKLicenceActivity"
            android:configChanges="orientation|keyboardHidden|navigation"
            android:excludeFromRecents="true"
            android:theme="@style/DK.Theme.NoBackGround.NoAnimation"
            android:screenOrientation="portrait">
        </activity>
        <activity
            android:name="com.duoku.platform.ui.DKReqBindPhoneActivity"
            android:configChanges="orientation|keyboardHidden|navigation"
            android:excludeFromRecents="true"
            android:theme="@style/DK.Theme.NoBackGround.NoAnimation"
            android:screenOrientation="portrait">
        </activity>
        <activity 
            android:name="com.duoku.platform.ui.DKFindPwdActivity"
            android:configChanges="orientation|keyboardHidden|navigation"
            android:screenOrientation="portrait"
            android:theme="@style/DK.Theme.NoBackGround.NoAnimation">
        </activity> 
		<!-- end duoku -->
        
    </application>

</manifest>