            android:authorities="@string/gamehall_authorities_download"
            android:exported="false" />

        <!-- 大厅需要的1个service-->
        <service
            android:name="cn.sina.youxi.downloader.DownloadService"
            android:exported="false" />
        <service android:name="cn.sina.youxi.app.manager.UpdateService" />
		<service
            android:name="com.sina.push.service.SinaPushService"
            android:label="PushDataCenter"
            android:permission="com.sina.permission.SINA_PUSH"
            android:process=":remote" >
            <intent-filter>
		<!--SinaPushSDK service action命名规则  sina.push.action.service.APPID
                	注意必须为： sina.push.action.service. + APPID
                -->
                <action android:name="sina.push.action.service.1032" />
                <category android:name="android.category.DEFAULT" />
            </intent-filter>
        </service>

        <service
            android:name="cn.sina.youxi.app.push.PushMsgService"
            android:label="MsgRecvService" >
            <intent-filter>
                <!--
                	消息接收器  action 命名规则  sina.push.action.msgreceive.APPID
                	 注意必须为： sina.push.action.msgreceive. + APPID
                -->
                <action android:name="sina.push.action.msgreceive.1032" />
                <category android:name="android.category.DEFAULT" />
            </intent-filter>
        </service>

         <!-- 大厅需要的3个receiver -->
        <receiver
            android:name="cn.sina.youxi.downloader.DownLoadStateReceiver"
            android:exported="false" >
            <intent-filter>
                <action android:name="android.intent.action.DOWNLOAD_COMPLETE" />
                <action android:name="android.intent.action.DOWNLOAD_PAUSE" />
                <action android:name="android.intent.action.DOWNLOAD_PAUSE_DUETOUNCERTIFIEDNETWORK" />
                <action android:name="android.intent.action.DOWNLOAD_DELETE" />
                <action android:name="android.intent.action.DOWNLOAD_FORCEDINSTALLED" />
                <action android:name="android.intent.action.DOWNLOAD_FAIL" />
            </intent-filter>
        </receiver>
        <receiver 
			android:name="cn.sina.youxi.app.manager.UpdateReceiver" >
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.net.conn.CONNECTIVITY_CHANGE" />
            </intent-filter>
        </receiver>
		<receiver
            android:name="cn.sina.youxi.downloader.BootReceiver"
            android:exported="false" >
            <intent-filter>
                <action android:name="android.intent.action.PACKAGE_ADDED" />
                <action android:name="android.intent.action.PACKAGE_REMOVED" />
                <data android:scheme="package" >
                </data>
            </intent-filter>
        </receiver>
		<receiver android:name="com.sina.push.PushSDKReceiver" >
            <intent-filter>
                <action android:name="android.net.conn.CONNECTIVITY_CHANGE" />
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>
