    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW"/>
    
    <uses-permission android:name="android.permission.SEND_SMS" />
    <uses-permission android:name="android.permission.RECEIVE_SMS" />
    <uses-permission android:name="android.permission.CALL_PHONE" />
    
    
    <!-- sina微博 大厅需要的uses-permission start -->
    <!-- Allows access to the Download Manager -->
    <uses-permission android:name="cn.sina.youxi.permission.ACCESS_DOWNLOAD_MANAGER" />
    <uses-permission android:name="cn.sina.youxi.permission.ACCESS_DOWNLOAD_MANAGER_ADVANCED" />
    <uses-permission android:name="cn.sina.youxi.permission.SEND_DOWNLOAD_COMPLETED_INTENTS" />
    <uses-permission android:name="com.android.launcher.permission.INSTALL_SHORTCUT" />
    <uses-permission android:name="com.android.launcher.permission.UNINSTALL_SHORTCUT" />
    <uses-permission android:name="com.android.launcher.permission.READ_SETTINGS" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />
    <uses-permission android:name="android.permission.READ_LOGS" />
    <uses-permission android:name="android.permission.RESTART_PACKAGES" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
	
	<!-- -->
	<!-- 360快捷支付必须的权限 -->
    <uses-permission android:name="android.permission.READ_SMS" />
    <!--
    <uses-permission android:name="android.permission.WAKE_LOCK" />
	-->

    <supports-screens android:largeScreens="true"
                      android:smallScreens="true"
                      android:anyDensity="true"
                      android:normalScreens="true"
                      android:xlargeScreens="true"/>

    <!-- android:debuggable="true" ADT&NDK自动处理了 -->
    
    <!-- 发布修改icon -->
    
    <application
        android:name = "cn.sina.youxi.app.BaseApplication"
        android:allowBackup="true"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:theme="@android:style/Theme.NoTitleBar.Fullscreen" 
        android:largeHeap="true" 
        android:vmSafeMode="false" 
        android:allowClearUserData="true"
        android:debuggable="false">
        
        <!-- 发布指定平台：
        1	nd91.Nd91Activity
        2	uc.UcActivity
        3	qihoo360.Qihoo360Activity
        4	dangle.DangLeActivity
        5	mi.XiaoMiActivity
        6	wandoujia.WanDouJiaActivity
		7   DK.DuokuActivity
		15  sina_wyx.SinaActivity
        
         -->
        <activity
            android:name="com.youai.dreamonepiece.platform.sina_wyx.SinaActivity"
            android:label="@string/app_name"
            android:theme="@android:style/Theme.NoTitleBar.Fullscreen" 
            android:launchMode="singleTop" 
            android:screenOrientation="portrait">
            <intent-filter>
			    <action android:name="com.youai.dreamonepiece.platform.sina_wyx.MAINACTION" />
			    <data android:host="MainActivity" android:scheme="gamehall" />
			    <category android:name="android.intent.category.DEFAULT" />
		    </intent-filter>
        </activity>
        <!--  -->
        
		<!-- sina begin -->
		<!-- sina的appkey -->
        <meta-data
            android:name="WYX_APPKEY"
            android:value="WYX_3883789765" >
        </meta-data>
         <!-- sina的appSecret -->
        <meta-data
            android:name="WYX_APPSECRET"
            android:value="WYX_91d0066a5ee294695d9ca4681f517dff" >
        </meta-data>
        <!-- sina的渠道值 GAMEHALL_100010041000 GAMEHALL_100010051000 GAMEHALL_101010001000 GAMEHALL_100610061000 GAMEHALL_101310001000 GAMEHALL_101510001000-->
        <meta-data
            android:name="GAMEHALL_CHANNEL"
            android:value="GAMEHALL_101510001000" >
        </meta-data>
		  <!-- 大厅需要的2个provider-->
        <provider
            android:name="cn.sina.youxi.app.mine.PlayedGameContentProvider"
            android:authorities="com.youai.dreamonepiece.platform.sina_wyx.providers.playedgameprovider"
            android:exported="true"
            android:multiprocess="true" />
        <provider
            android:name="cn.sina.youxi.downloader.DownloadProvider"
            android:authorities="com.youai.dreamonepiece.platform.sina_wyx.providers.downloadprovider"
            android:exported="false" />
        
        <!-- 大厅需要的1个service-->
        <service
            android:name="cn.sina.youxi.downloader.DownloadService"
            android:exported="false" />
         <!-- 大厅需要的3个receiver -->
        <receiver
            android:name="cn.sina.youxi.downloader.DownloadReceiver"
            android:exported="false" >
            <intent-filter>
                <action android:name="android.net.conn.CONNECTIVITY_CHANGE" />
                <action android:name="android.intent.action.DOWNLOAD_WAKEUP" />
                <action android:name="android.intent.action.DOWNLOAD_OPEN" />
                <action android:name="android.intent.action.DOWNLOAD_LIST" />
                <action android:name="android.intent.action.DOWNLOAD_HIDE" />
                <data android:scheme="content"></data>
            </intent-filter>
        </receiver>
        <receiver
            android:name="cn.sina.youxi.app.receiver.DownLoadCompleteReceiver"
            android:exported="false" >
            <intent-filter>
                <action android:name="android.intent.action.DOWNLOAD_NOTIFICATION_CLICKED" />
                <action android:name="android.intent.action.DOWNLOAD_COMPLETE" />
                <action android:name="android.intent.action.VIEW_DOWNLOADS" />
            </intent-filter>
        </receiver>
        <receiver
            android:name="cn.sina.youxi.app.receiver.BootReceiver"
            android:exported="false" >
            <intent-filter>
                <action android:name="android.intent.action.PACKAGE_ADDED" />
                <action android:name="android.intent.action.PACKAGE_REPLACED" />
                <action android:name="android.intent.action.PACKAGE_REMOVED" />
                <data android:scheme="package"></data>
            </intent-filter>
        </receiver>
        <activity
            android:name="cn.sina.youxi.app.GameHallMainActivity"
            android:configChanges="orientation|keyboardHidden|navigation"
            android:launchMode="singleTop"
            android:screenOrientation="portrait"
            android:theme="@android:style/Theme.Black.NoTitleBar"
            android:windowSoftInputMode="adjustPan" >
			<intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name="cn.sina.youxi.app.home.HomeMainActivity"
