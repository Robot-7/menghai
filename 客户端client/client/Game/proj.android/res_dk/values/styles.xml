<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--
        Base application theme, dependent on API level. This theme is replaced
        by AppBaseTheme from res/values-vXX/styles.xml on newer devices.
    -->
    <style name="AppBaseTheme" parent="android:Theme.Light">
        <!--
            Theme customizations available in newer API levels can go in
            res/values-vXX/styles.xml, while customizations related to
            backward-compatibility can go here.
        -->
    </style>

    <!-- Application theme. -->
    <style name="AppTheme" parent="AppBaseTheme">
        <!-- All customizations that are NOT specific to a particular API-level can go here. -->
    </style>

    <style name="FullscreenTheme" parent="android:Theme.NoTitleBar">
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowBackground">@null</item>
        <item name="buttonBarStyle">@style/ButtonBar</item>
        <item name="buttonBarButtonStyle">@style/ButtonBarButton</item>
    </style>

    <style name="ButtonBar">
        <item name="android:paddingLeft">2dp</item>
        <item name="android:paddingTop">5dp</item>
        <item name="android:paddingRight">2dp</item>
        <item name="android:paddingBottom">0dp</item>
        <item name="android:background">@android:drawable/bottom_bar</item>
    </style>

    <style name="ButtonBarButton" />

    <style name="FloatingWindowStyle">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">true</item>
    </style>
    
    <style name="DialogActivity" parent="@android:style/Theme">
        <item name="android:windowNoTitle">true</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowFrame">@null</item>
        <item name="android:windowIsTranslucent">true</item>
    </style>
    
    
    <style name="AppTheme" parent="android:Theme.Light" />
	
    <style name="myDialogTheme" parent="android:Theme.Dialog" >
        <item name="android:windowFrame">@null</item>
       <item name="android:windowNoTitle">true</item>                             
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:backgroundDimEnabled">false</item>
        <item name="android:windowBackground">@color/dk_transparent</item>
    </style>
    
    <style name="tabbar_top_style" >
        <item name="android:layout_height">48dp</item>
        <item name="android:layout_width">fill_parent</item>
        <item name="android:background">@drawable/dk_bg_ab</item>
    </style>
    
    <!-- The style of payment buttons -->
    <style name="payment_button_style">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">56dp</item>
        <item name="android:gravity">center</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_marginLeft">12dp</item>
        <item name="android:textColor">#666666</item>
        <item name="android:textSize">@dimen/text_size_12_sp</item>
        <item name="android:background">@drawable/dk_payment_btn_card_big_selector</item>
    </style>
    
    <!-- The style of  payment scrollViews-->
    <style name="payment_scrollview_style">
        <item name="android:fadeScrollbars">false</item>
        <item name="android:scrollbarStyle">insideOverlay</item>
        <item name="android:scrollbarSize">4dp</item>
        <item name="android:scrollbarThumbVertical">@drawable/dk_scrollbar</item>
        <item name="android:scrollbarThumbHorizontal">@drawable/dk_scrollbar</item>
    </style>
    
    <!-- The style of payment activity dialog background -->
    <style name="Theme.TransparentBgDialog" parent="android:style/Theme.Dialog">
    	<item name="android:windowBackground">@drawable/dk_payment_activity_dialog_bg</item>
	</style>
	<style name="DK.Theme.NoBackGround" parent="android:style/Theme.NoTitleBar.Fullscreen">
	    <item name="android:windowIsTranslucent">true</item>
	    <item name="android:windowBackground">@color/dk_transparent</item>
	</style>
	
	<!-- The style of custom dialog -->
	 <style name="payment_dialog_style" parent="@android:Theme.Dialog">
        <item name="android:windowFrame">@null</item>
        <item name="android:windowNoTitle">true</item> 
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowBackground">@drawable/dk_bg_dialog</item>
    </style>
	
	<style name="DK.Theme.NoBackGround.NoAnimation" parent="DK.Theme.NoBackGround">
	    <item name="android:windowAnimationStyle">@null</item>  
	</style>
	
	<!-- add by wenzutong, style of user edittext -->
	<style name="dk_style_user_edittext">
	    <item name="android:layout_width">fill_parent</item>
	    <item name="android:layout_height">40dp</item>
	    <item name="android:background">@drawable/dk_edittext_selector</item>
	    <item name="android:singleLine">true</item>
	    <item name="android:textSize">14sp</item>
	    <item name="android:textColorHint">@color/dk_color_999999</item>
	    <item name="android:gravity">center_vertical</item>
	</style>
    <!-- end -->
</resources>