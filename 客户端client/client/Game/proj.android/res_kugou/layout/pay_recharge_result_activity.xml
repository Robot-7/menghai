<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:orientation="vertical" >

    <include
        android:layout_weight="1"
        layout="@layout/pay_common_title_bar" />

    <include
        android:layout_weight="1"
        layout="@layout/pay_common_tips_bar" />

    <LinearLayout
        android:id="@+id/pay_waitting_result_layout"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:layout_weight="1"
        android:background="@drawable/pay_common_bg"
        android:gravity="center_horizontal"
        android:orientation="vertical" >

        <Button
            android:id="@+id/pay_check_recharge_state_button"
            android:layout_width="250dip"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dip"
            android:background="@drawable/kgpaysdk_green_button_bg_selector"
            android:shadowColor="#ff000fff"
            android:text="查看本次游戏充值结果"
            android:textColor="#ffffffff" />

        <Button
            android:id="@+id/pay_loginout_kugou_game_center_button"
            android:layout_width="250dip"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dip"
            android:background="@drawable/kgpaysdk_white_button_bg_selector"
            android:shadowColor="#ffffffff"
            android:text="退出酷狗游戏充值中心"
            android:textColor="#ff000000" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/pay_recharge_success_layout"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:layout_weight="1"
        android:background="@drawable/pay_common_bg"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:visibility="gone" >

        <LinearLayout
            android:layout_marginTop="20dip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal" >

            <ImageView
                android:id="@+id/recharge_result_flag_image"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/pay_edittext_success_flag" />

            <TextView
                android:id="@+id/recharge_result_flag_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="5dip"
                android:text="恭喜你，成功充值！"
                android:textColor="#ff666666"
                android:textSize="20dip" />
        </LinearLayout>

        <Button
            android:id="@+id/pay_back_to_the_game_from_recharge_result_button"
            android:layout_width="250dip"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dip"
            android:background="@drawable/kgpaysdk_green_button_bg_selector"
            android:shadowColor="#ff000fff"
            android:text="返回游戏"
            android:textColor="#ffffffff" />

        <Button
            android:id="@+id/pay_continue_to_recharge_from_recharge_result_button"
            android:layout_width="250dip"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dip"
            android:background="@drawable/kgpaysdk_green_button_bg_selector"
            android:shadowColor="#ff000fff"
            android:text="继续充值"
            android:textColor="#ffffffff" />
    </LinearLayout>

    <include
        android:layout_weight="1"
        layout="@layout/pay_bottom_bar" />

</LinearLayout>