<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:orientation="vertical" >

    <include
        android:layout_weight="1"
        layout="@layout/pay_common_title_bar" />

    <include
        android:layout_weight="1"
        layout="@layout/pay_common_tips_bar" />

    <LinearLayout
        android:id="@+id/pay_layout_charge_history"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:layout_weight="1"
        android:background="@drawable/pay_common_bg"
        android:gravity="center_horizontal"
        android:orientation="vertical" >

        <LinearLayout
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dip" >

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_horizontal"
                android:text="时间"
                android:textColor="@android:color/black"
                android:textSize="16dip" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_horizontal"
                android:text="充值金额"
                android:textColor="@android:color/black"
                android:textSize="16dip" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_horizontal"
                android:text="支付方式"
                android:textColor="@android:color/black"
                android:textSize="16dip" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_horizontal"
                android:text="充值项目"
                android:textColor="@android:color/black"
                android:textSize="16dip" />
        </LinearLayout>

        <ListView
            android:id="@+id/pay_charge_history_list"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            android:divider="@android:color/darker_gray"
            android:dividerHeight="1px" >
        </ListView>
    </LinearLayout>

    <com.kugou.pay.android.widget.LoadingView
        android:id="@+id/pay_loading"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:layout_weight="1"
        android:background="@drawable/pay_common_bg"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/pay_summit_successed_layout"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:layout_weight="1"
        android:background="@drawable/pay_common_bg"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:visibility="gone" >

        <LinearLayout
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dip"
            android:gravity="center"
            android:orientation="horizontal" >

            <ImageView
                android:id="@+id/pay_summit_imgae_flag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/pay_edittext_fail_flag" />

            <TextView
                android:id="@+id/pay_summit_text_flag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dip"
                android:text="很抱歉，获取充值历史失败！"
                android:textColor="#ff000022"
                android:textSize="20dip" />
        </LinearLayout>

        <Button
            android:id="@+id/pay_back_to_the_request_again"
            android:layout_width="250dip"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dip"
            android:background="@drawable/kgpaysdk_green_button_bg_selector"
            android:shadowColor="#ff000fff"
            android:text="再来一次"
            android:textColor="#ffffffff" />
    </LinearLayout>

    <include
        android:layout_weight="1"
        layout="@layout/pay_bottom_bar" />

</LinearLayout>