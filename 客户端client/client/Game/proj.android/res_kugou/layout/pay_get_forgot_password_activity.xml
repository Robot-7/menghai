<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:orientation="vertical" >

    <include
        android:layout_weight="1"
        layout="@layout/pay_common_title_bar" />

    <include
        android:layout_weight="1"
        layout="@layout/pay_common_tips_bar" />

    <LinearLayout
        android:id="@+id/pay_layout_userlogin"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:layout_weight="1"
        android:background="@drawable/pay_common_bg"
        android:gravity="center_horizontal"
        android:orientation="vertical" >

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="8dip"
            android:layout_marginTop="20dip"
            android:gravity="center_vertical"
            android:orientation="horizontal" >

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="帐号："
                android:textColor="#ff666666"
                android:textSize="16dip" />

            <TextView
                android:id="@+id/pay_get_forgot_password_accout"
                android:layout_width="230dip"
                android:layout_height="35dip"
                android:gravity="center_vertical"
                android:singleLine="true"
                android:textColor="@android:color/black"
                android:textSize="16dip" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dip"
            android:gravity="center_vertical"
            android:orientation="horizontal" >

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="新密码："
                android:textColor="#ff666666"
                android:textSize="16dip" />

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" >

                <EditText
                    android:id="@+id/pay_login_phone_number"
                    android:layout_width="200dip"
                    android:layout_height="35dip"
                    android:background="@drawable/pay_sp_bg"
                    android:digits="0123456789abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ"
                    android:hint="限6-16位字母/数字"
                    android:maxLength="16"
                    android:paddingRight="30dip"
                    android:password="true"
                    android:textColor="@android:color/black"
                    android:singleLine="true"
                    android:textSize="16dip" />

                <ImageView
                    android:id="@+id/pay_login_phone_clear"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center|right"
                    android:layout_marginLeft="5dip"
                    android:layout_marginRight="5dip"
                    android:src="@drawable/pay_text_clear"
                    android:visibility="invisible" />
            </FrameLayout>

            <ImageView
                android:id="@+id/pay_login_phone_number_check"
                android:layout_width="25dip"
                android:layout_height="25dip"
                android:layout_marginLeft="5dip"
                android:visibility="invisible" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dip"
            android:gravity="center_vertical"
            android:orientation="horizontal" >

            <Button
                android:id="@+id/pay_summit_get_password_back_button"
                android:layout_width="250dip"
                android:layout_height="wrap_content"
                android:background="@drawable/kgpaysdk_green_button_bg_selector"
                android:shadowColor="#ff000fff"
                android:text="确定提交"
                android:textColor="#ffffffff" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/pay_layout_login_success"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:layout_weight="1"
        android:background="@drawable/pay_common_bg"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:visibility="gone" >

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dip"
            android:gravity="center_vertical"
            android:orientation="horizontal" >

            <ImageView
                android:id="@+id/pay_login_phone_check"
                android:layout_width="25dip"
                android:layout_height="25dip"
                android:layout_marginLeft="5dip" />

            <TextView
                android:id="@+id/pay_login_phone_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="恭喜你成功修改登录密码"
                android:textColor="#ff666666"
                android:textSize="20dip" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dip"
            android:gravity="center_vertical"
            android:orientation="horizontal" >

            <Button
                android:id="@+id/pay_summit_get_password_button"
                android:layout_width="250dip"
                android:layout_height="wrap_content"
                android:background="@drawable/kgpaysdk_green_button_bg_selector"
                android:shadowColor="#ff000fff"
                android:text="登录游戏"
                android:textColor="#ffffffff" />
        </LinearLayout>
    </LinearLayout>

    <com.kugou.pay.android.widget.LoadingView
        android:id="@+id/pay_loading"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:layout_weight="1"
        android:background="@drawable/pay_common_bg"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:visibility="gone" />

    <include
        android:layout_weight="1"
        layout="@layout/pay_bottom_bar" />

</LinearLayout>