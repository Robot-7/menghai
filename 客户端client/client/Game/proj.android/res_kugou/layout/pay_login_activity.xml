<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:orientation="vertical" >

    <include
        android:layout_weight="1"
        layout="@layout/pay_common_title_bar" />

    <include
        android:layout_weight="1"
        layout="@layout/pay_common_tips_bar" />

    <LinearLayout
        android:id="@+id/pay_layout_userlogin"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:layout_weight="1"
        android:background="@drawable/pay_common_bg"
        android:gravity="center_horizontal"
        android:orientation="vertical" >

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="3dip"
            android:layout_marginTop="20dip"
            android:gravity="center_vertical"
            android:orientation="horizontal" >

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="帐号："
                android:textColor="#ff666666"
                android:textSize="16dip" />

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" >

                <EditText
                    android:id="@+id/pay_login_username"
                    android:layout_width="215dip"
                    android:layout_height="35dip"
                    android:background="@drawable/pay_sp_bg"
                    android:hint="限4-20位字母/数字"
                    android:maxLength="20"
                    android:textColor="@android:color/black"
                    android:paddingRight="60dip"
                    android:singleLine="true"
                    android:textSize="16dip" >
                </EditText>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical|right"
                    android:gravity="center_vertical"
                    android:orientation="horizontal" >

                    <ImageView
                        android:id="@+id/pay_login_username_clear"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="5dip"
                        android:layout_marginRight="5dip"
                        android:src="@drawable/pay_text_clear"
                        android:visibility="invisible" />

                    <ImageView
                        android:id="@+id/pay_account_select"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="5dip"
                        android:layout_marginRight="5dip"
                        android:src="@drawable/pay_account_select" />
                </LinearLayout>
            </FrameLayout>

            <ImageView
                android:id="@+id/pay_login_username_check"
                android:layout_width="25dip"
                android:layout_height="25dip"
                android:layout_marginLeft="5dip" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="3dip"
            android:layout_marginTop="10dip"
            android:gravity="center_vertical"
            android:orientation="horizontal" >

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="密码："
                android:textColor="#ff666666"
                android:textSize="16dip" />

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" >

                <EditText
                    android:id="@+id/pay_login_password"
                    android:layout_width="215dip"
                    android:layout_height="35dip"
                    android:background="@drawable/pay_sp_bg"
                    android:digits="0123456789abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ"
                    android:hint="限6-16位字母/数字"
                    android:maxLength="16"
                    android:paddingRight="30dip"
                    android:password="true"
                    android:textColor="@android:color/black"
                    android:singleLine="true"
                    android:textSize="16dip" />

                <ImageView
                    android:id="@+id/pay_login_password_clear"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center|right"
                    android:layout_marginLeft="5dip"
                    android:layout_marginRight="5dip"
                    android:src="@drawable/pay_text_clear"
                    android:visibility="invisible" />
            </FrameLayout>

            <ImageView
                android:id="@+id/pay_login_password_check"
                android:layout_width="25dip"
                android:layout_height="25dip"
                android:layout_marginLeft="5dip" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dip"
            android:gravity="center_vertical"
            android:orientation="vertical" >

            <Button
                android:id="@+id/pay_start_login_button"
                android:layout_width="250dip"
                android:layout_height="wrap_content"
                android:background="@drawable/kgpaysdk_green_button_bg_selector"
                android:shadowColor="#ff000fff"
                android:text="立即登录"
                android:textColor="#ffffffff" />

            <Button
                android:id="@+id/pay_start_reg_imdi_button"
                android:layout_width="250dip"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dip"
                android:background="@drawable/kgpaysdk_blue_button_bg_selector"
                android:shadowColor="#ff000fff"
                android:text="1秒免费注册"
                android:textColor="#ffffffff" />
        </LinearLayout>

        <TextView
            android:id="@+id/pay_login_forgot_password"
            android:layout_width="wrap_content"
            android:layout_height="40dip"
            android:layout_gravity="right"
            android:layout_marginRight="50dip"
            android:layout_marginTop="15dip"
            android:textColor="#FF6600"
            android:textSize="16dip" />
    </LinearLayout>

    <com.kugou.pay.android.widget.LoadingView
        android:id="@+id/pay_loading"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:layout_weight="1"
        android:background="@drawable/pay_common_bg"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:visibility="gone" />

    <include
        android:layout_weight="1"
        layout="@layout/pay_bottom_bar" />

</LinearLayout>