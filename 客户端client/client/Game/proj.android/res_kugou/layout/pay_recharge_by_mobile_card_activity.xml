<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:orientation="vertical" >

    <include
        android:layout_weight="1"
        layout="@layout/pay_common_title_bar" />

    <LinearLayout
        android:id="@+id/pay_common_tips_bar_and_hide"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:layout_weight="1"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:visibility="gone" >

        <include layout="@layout/pay_common_tips_bar" />

        <com.kugou.pay.android.widget.LoadingView
            android:id="@+id/pay_loading"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            android:background="@drawable/pay_common_bg"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:visibility="gone" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/pay_select_charge_layout"
        android:layout_width="fill_parent"
        android:layout_height="160dip"
        android:layout_weight="1"
        android:background="@drawable/pay_common_bg"
        android:orientation="horizontal" >

        <Button
            android:id="@+id/pay_use_china_mobile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="3dip"
            android:layout_weight="1"
            android:background="@drawable/pay_mobile_card_bg_pressed"
            android:text="移动充值卡"
            android:textColor="#ffffffff" />

        <Button
            android:id="@+id/pay_use_china_unicom"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="3dip"
            android:layout_weight="1"
            android:background="@drawable/pay_mobile_card_bg"
            android:text="联通充值卡"
            android:textColor="#ff4B9813" />

        <Button
            android:id="@+id/pay_use_china_telecom"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="3dip"
            android:layout_weight="1"
            android:background="@drawable/pay_mobile_card_bg"
            android:text="电信充值卡"
            android:textColor="#ff4B9813" />
    </LinearLayout>

    <ScrollView
        android:id="@+id/pay_input_charge_layout"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:layout_weight="1"
        android:background="@drawable/pay_common_bg" >

        <LinearLayout
            android:id="@+id/pay_layout_grid_card_money"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            android:layout_weight="1"
            android:gravity="center_horizontal"
            android:orientation="vertical" >

            <LinearLayout
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:layout_marginTop="10dip"
                android:gravity="left"
                android:orientation="horizontal" >

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="10dip"
                    android:text="充值金额："
                    android:textColor="#ff666666"
                    android:textSize="16dip" />
            </LinearLayout>

            <GridView
                android:id="@+id/recharge_grid_seletor"
                android:layout_width="fill_parent"
                android:layout_height="90dip"
                android:layout_margin="10dip"
                android:listSelector="@drawable/kgpaysdk_transparent"
                android:numColumns="4"
                android:scrollbars="none" />

            <TextView
                android:id="@+id/pay_recharge_tips"
                android:layout_width="210dip"
                android:layout_height="wrap_content"
                android:layout_marginLeft="9dip"
                android:background="@drawable/pay_yello_bg"
                android:padding="5dip"
                android:textColor="#ff000000"
                android:textSize="16dip" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dip"
                android:gravity="center_vertical"
                android:orientation="horizontal" >

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="卡号："
                    android:textColor="#ff666666"
                    android:textSize="16dip" />

                <FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="3dip" >

                    <EditText
                        android:id="@+id/pay_rechargecard_number"
                        android:layout_width="210dip"
                        android:layout_height="35dip"
                        android:background="@drawable/pay_sp_bg"
                        android:numeric="integer"
                        android:paddingRight="30dip"
                        android:singleLine="true"
                        android:textColor="@android:color/black"
                        android:textSize="16dip" >
                    </EditText>

                    <ImageView
                        android:id="@+id/pay_rechargecard_number_clear"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center|right"
                        android:layout_marginLeft="5dip"
                        android:layout_marginRight="5dip"
                        android:src="@drawable/pay_text_clear"
                        android:visibility="invisible" />
                </FrameLayout>

                <ImageView
                    android:id="@+id/pay_rechargecard_number_check"
                    android:layout_width="25dip"
                    android:layout_height="25dip"
                    android:layout_marginLeft="5dip"
                    android:visibility="invisible" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dip"
                android:gravity="center_vertical"
                android:orientation="horizontal" >

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="密码："
                    android:textColor="#ff666666"
                    android:textSize="16dip" />

                <FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="3dip" >

                    <EditText
                        android:id="@+id/pay_rechargecard_password"
                        android:layout_width="210dip"
                        android:layout_height="35dip"
                        android:background="@drawable/pay_sp_bg"
                        android:numeric="integer"
                        android:paddingRight="30dip"
                        android:singleLine="true"
                        android:textColor="@android:color/black"
                        android:textSize="16dip" >
                    </EditText>

                    <ImageView
                        android:id="@+id/pay_rechargecard_password_clear"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center|right"
                        android:layout_marginLeft="5dip"
                        android:layout_marginRight="5dip"
                        android:src="@drawable/pay_text_clear"
                        android:visibility="invisible" />
                </FrameLayout>

                <ImageView
                    android:id="@+id/pay_rechargecard_password_check"
                    android:layout_width="25dip"
                    android:layout_height="25dip"
                    android:layout_marginLeft="5dip"
                    android:visibility="invisible" />
            </LinearLayout>

            <Button
                android:id="@+id/pay_summit_recharge_button"
                android:layout_width="250dip"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dip"
                android:background="@drawable/kgpaysdk_green_button_bg_selector"
                android:shadowColor="#ff000fff"
                android:text="确认充值"
                android:textColor="#ffffffff" />

            <TextView
                android:id="@+id/pay_long_recharge_tips"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:layout_marginTop="27dip"
                android:padding="5dip"
                android:textColor="#ff666666"
                android:textSize="13dip" />
        </LinearLayout>
    </ScrollView>

    <include
        android:layout_weight="1"
        layout="@layout/pay_bottom_bar" />

</LinearLayout>