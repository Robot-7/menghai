<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:orientation="vertical" >

    <include
        android:layout_weight="1"
        layout="@layout/pay_common_title_bar" />

    <include
        android:layout_weight="1"
        layout="@layout/pay_common_tips_bar" />

    <LinearLayout
        android:id="@+id/pay_layout_bind_phone"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:layout_weight="1"
        android:background="@drawable/pay_common_bg"
        android:gravity="center_horizontal"
        android:orientation="vertical" >

        <LinearLayout
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dip"
            android:gravity="center_horizontal"
            android:orientation="horizontal" >

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginLeft="18dip"
                android:text="帐号："
                android:textColor="#ff666666"
                android:textSize="16dip" />

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" >

                <EditText
                    android:id="@+id/pay_get_password_accout"
                    android:layout_width="200dip"
                    android:layout_height="35dip"
                    android:background="@drawable/pay_sp_bg"
                    android:digits="0123456789abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ"
                    android:maxLength="20"
                    android:textSize="16dip"
                    android:paddingRight="30dip"
                    android:textColor="@android:color/black"
                    android:singleLine="true" />

                <ImageView
                    android:id="@+id/pay_login_username_clear"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center|right"
                    android:layout_marginLeft="5dip"
                    android:layout_marginRight="5dip"
                    android:src="@drawable/pay_text_clear"
                    android:visibility="invisible" />
            </FrameLayout>

            <ImageView
                android:id="@+id/pay_login_username_check"
                android:layout_width="25dip"
                android:layout_height="25dip"
                android:layout_gravity="center"
                android:layout_marginLeft="5dip" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dip"
            android:gravity="center_vertical"
            android:orientation="horizontal" >

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="手机号："
                android:textColor="#ff666666"
                android:textSize="16dip" />

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" >

                <EditText
                    android:id="@+id/pay_get_password_phone"
                    android:layout_width="200dip"
                    android:layout_height="35dip"
                    android:background="@drawable/pay_sp_bg"
                    android:maxLength="11"
                    android:numeric="integer"
                    android:paddingRight="30dip"
                    android:phoneNumber="true"
                    android:textSize="16dip"
                    android:textColor="@android:color/black"
                    android:singleLine="true" />

                <ImageView
                    android:id="@+id/pay_login_phone_clear"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center|right"
                    android:layout_marginLeft="5dip"
                    android:layout_marginRight="5dip"
                    android:src="@drawable/pay_text_clear"
                    android:visibility="invisible" />
            </FrameLayout>

            <ImageView
                android:id="@+id/pay_login_phone_check"
                android:layout_width="25dip"
                android:layout_height="25dip"
                android:layout_marginLeft="5dip" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="200dip"
            android:layout_height="wrap_content"
            android:layout_marginLeft="17dip"
            android:layout_marginTop="10dip"
            android:orientation="vertical" >

            <Button
                android:id="@+id/pay_get_Dynamic_password"
                android:layout_width="200dip"
                android:layout_height="wrap_content"
                android:background="@drawable/kgpaysdk_mobile_card_seletor"
                android:text="点击获取短信验证码"
                android:textColor="@android:color/black" />

            <TextView
                android:id="@+id/pay_get_Dynamic_password_text"
                android:layout_width="200dip"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dip"
                android:text="短信验证码已发送（今天剩余x次）"
                android:textSize="11dip"
                android:visibility="gone" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dip"
            android:gravity="center_vertical"
            android:orientation="horizontal" >

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="验证码："
                android:textColor="#ff666666"
                android:textSize="16dip" />

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" >

                <EditText
                    android:id="@+id/pay_get_Dynamic_password_edittext"
                    android:layout_width="200dip"
                    android:layout_height="35dip"
                    android:background="@drawable/pay_sp_bg"
                    android:digits="0123456789abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ"
                    android:hint="填写短信中的验证码"
                    android:maxLength="16"
                    android:textSize="16dip"
                    android:textColor="@android:color/black"
                    android:paddingRight="30dip"
                    android:singleLine="true" />

                <ImageView
                    android:id="@+id/pay_repet_password_clear"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center|right"
                    android:layout_marginLeft="5dip"
                    android:layout_marginRight="5dip"
                    android:src="@drawable/pay_text_clear"
                    android:visibility="invisible" />
            </FrameLayout>

            <ImageView
                android:id="@+id/pay_repet_password_check"
                android:layout_width="25dip"
                android:layout_height="25dip"
                android:layout_marginLeft="5dip" />
        </LinearLayout>

        <Button
            android:id="@+id/pay_summit_get_password_back_button"
            android:layout_width="250dip"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dip"
            android:background="@drawable/kgpaysdk_green_button_bg_selector"
            android:shadowColor="#ff000fff"
            android:text="确认提交"
            android:textColor="#ffffffff" />

        <LinearLayout
            android:id="@+id/pay_layout_bind_phone_description"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            android:gravity="left|bottom"
            android:orientation="vertical" >

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="未绑定手机号码的用户,可以联系酷狗游戏客服人工找回。"
                android:textColor="@android:color/darker_gray"
                android:textSize="14dip" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="客服热线：4008884006"
                android:textColor="@android:color/darker_gray"
                android:textSize="14dip" />
        </LinearLayout>
    </LinearLayout>

    <com.kugou.pay.android.widget.LoadingView
        android:id="@+id/pay_loading"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:layout_weight="1"
        android:background="@drawable/pay_common_bg"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:visibility="gone" />

    <include
        android:layout_weight="1"
        layout="@layout/pay_bottom_bar" />

</LinearLayout>