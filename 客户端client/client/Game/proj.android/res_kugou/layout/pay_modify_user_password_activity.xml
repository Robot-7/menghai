<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:orientation="vertical" >

    <include
        android:layout_weight="1"
        layout="@layout/pay_common_title_bar" />

    <include
        android:layout_weight="1"
        layout="@layout/pay_common_tips_bar" />

    <LinearLayout
        android:id="@+id/pay_layout_modiy_user_password"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:layout_weight="1"
        android:background="@drawable/pay_common_bg"
        android:gravity="center_horizontal"
        android:orientation="vertical" >

        <LinearLayout
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dip"
            android:gravity="center_horizontal"
            android:orientation="horizontal" >

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="帐号："
                android:textColor="#ff666666"
                android:textSize="16dip" />

            <TextView
                android:id="@+id/pay_current_username_text"
                android:layout_width="193dip"
                android:layout_height="wrap_content"
                android:textColor="#ff666666"
                android:textSize="16dip" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dip"
            android:gravity="center_vertical"
            android:orientation="horizontal" >

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="原密码："
                android:textColor="#ff666666"
                android:textSize="16dip" />

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" >

                <EditText
                    android:id="@+id/pay_original_password"
                    android:layout_width="180dip"
                    android:layout_height="35dip"
                    android:background="@drawable/pay_sp_bg"
                    android:digits="0123456789abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ"
                    android:hint="原密码"
                    android:maxLength="16"
                    android:paddingRight="30dip"
                    android:singleLine="true"
                    android:textColor="@android:color/black"
                    android:textSize="16dip" />

                <ImageView
                    android:id="@+id/pay_original_password_clear"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center|right"
                    android:layout_marginLeft="5dip"
                    android:layout_marginRight="5dip"
                    android:src="@drawable/pay_text_clear"
                    android:visibility="invisible" />
            </FrameLayout>

            <ImageView
                android:id="@+id/pay_original_password_check"
                android:layout_width="25dip"
                android:layout_height="25dip"
                android:layout_marginLeft="5dip" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dip"
            android:gravity="center_vertical"
            android:orientation="horizontal" >

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="新密码："
                android:textColor="#ff666666"
                android:textSize="16dip" />

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" >

                <EditText
                    android:id="@+id/pay_repet_password"
                    android:layout_width="180dip"
                    android:layout_height="35dip"
                    android:background="@drawable/pay_sp_bg"
                    android:digits="0123456789abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ"
                    android:hint="限6-16位字母/数字"
                    android:maxLength="16"
                    android:paddingRight="30dip"
                    android:singleLine="true"
                    android:textColor="@android:color/black"
                    android:textSize="16dip" />

                <ImageView
                    android:id="@+id/pay_repet_password_clear"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center|right"
                    android:layout_marginLeft="5dip"
                    android:layout_marginRight="5dip"
                    android:src="@drawable/pay_text_clear"
                    android:visibility="invisible" />
            </FrameLayout>

            <ImageView
                android:id="@+id/pay_repet_password_check"
                android:layout_width="25dip"
                android:layout_height="25dip"
                android:layout_marginLeft="5dip" />
        </LinearLayout>

        <TextView
            android:id="@+id/pay_modify_user_password_tips"
            android:layout_width="250dip"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dip"
            android:background="@drawable/pay_yello_bg"
            android:padding="5dip"
            android:textColor="#ff000000"
            android:textSize="16dip" />

        <Button
            android:id="@+id/pay_summit_modify_user_password_button"
            android:layout_width="250dip"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dip"
            android:background="@drawable/kgpaysdk_green_button_bg_selector"
            android:shadowColor="#ff000fff"
            android:text="修改密码"
            android:textColor="#ffffffff" />
    </LinearLayout>

    <com.kugou.pay.android.widget.LoadingView
        android:id="@+id/pay_loading"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:layout_weight="1"
        android:background="@drawable/pay_common_bg"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/pay_summit_successed_layout"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:layout_weight="1"
        android:background="@drawable/pay_common_bg"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:visibility="gone" >

        <LinearLayout
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dip"
            android:gravity="center"
            android:orientation="horizontal" >

            <ImageView
                android:id="@+id/pay_summit_imgae_flag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/pay_edittext_success_flag" />

            <TextView
                android:id="@+id/pay_summit_text_flag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dip"
                android:text="恭喜你成功修改登录密码"
                android:textColor="#ff000022"
                android:textSize="20dip" />
        </LinearLayout>

        <Button
            android:id="@+id/pay_back_to_the_game_button"
            android:layout_width="250dip"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dip"
            android:background="@drawable/kgpaysdk_green_button_bg_selector"
            android:shadowColor="#ff000fff"
            android:text="返回游戏"
            android:textColor="#ffffffff" />
    </LinearLayout>

    <include
        android:layout_weight="1"
        layout="@layout/pay_bottom_bar" />

</LinearLayout>